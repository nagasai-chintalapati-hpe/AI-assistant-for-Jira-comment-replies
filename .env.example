# =============================================================================
# Jira Comment Assistant — Environment Configuration
# Copy this file to .env and fill in your values.
# Lines starting with # are comments and are ignored.
# =============================================================================


# ── Jira Cloud (REQUIRED) ────────────────────────────────────────────────────
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_USERNAME=your-email@company.com
JIRA_API_TOKEN=<Jira → Profile → Security → API tokens>


# ── Application ──────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
# Public URL of this service — used in Teams card review links
APP_BASE_URL=https://your-server.company.com
ASSISTANT_DB_PATH=.data/assistant.db
LOG_LEVEL=INFO
MAX_COMMENTS=10


# ── LLM Backend ──────────────────────────────────────────────────────────────
# Production: LLM_BACKEND=local  (on-prem Local LLM Server — see architecture)
# Dev/test:   LLM_BACKEND=none   (keyword classification + template drafts only)
LLM_BACKEND=local

# Local LLM (llama.cpp / GGUF) — used when LLM_BACKEND=local
LLM_MODEL_PATH=/models/mistral-7b-instruct.gguf
LLM_N_CTX=4096
LLM_N_GPU_LAYERS=35
LLM_N_THREADS=8
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=1024


# ── Webhook Security ─────────────────────────────────────────────────────────
# Set VALIDATE_WEBHOOK_SIGNATURE=true in production once Jira is configured
# with the same secret under Settings → System → Webhooks.
JIRA_WEBHOOK_SECRET=<random-secret-min-32-chars>
VALIDATE_WEBHOOK_SIGNATURE=false


# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_RPM=60


# ── Redis (optional — enables distributed rate limiting) ─────────────────────
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
# Full URL overrides host/port when set:
# REDIS_URL=redis://:password@redis-host:6379/0


# ── Message Queue / DMZ Relay (optional) ─────────────────────────────────────
# Set QUEUE_ENABLED=true when deploying with the DMZ Webhook Relay + RabbitMQ.
# The relay validates HMAC, publishes to the queue; the agent service consumes.
QUEUE_ENABLED=false
RABBITMQ_URL=amqp://guest:guest@localhost/
QUEUE_NAME=jira_webhook_events
QUEUE_PREFETCH_COUNT=1


# ── RAG ──────────────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=.data/chroma
RAG_EMBEDDING_MODEL=all-MiniLM-L6-v2
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=50
RAG_TOP_K=5
PDF_UPLOAD_DIR=.data/pdfs


# ── Confluence RAG ───────────────────────────────────────────────────────────
CONFLUENCE_BASE_URL=https://your-org.atlassian.net/wiki
CONFLUENCE_USERNAME=your-email@company.com
CONFLUENCE_API_TOKEN=<same Atlassian token as Jira>
CONFLUENCE_SPACES=TEAM,DOCS
CONFLUENCE_LABELS=


# ── S3 / MinIO Artifact Storage (optional) ───────────────────────────────────
S3_BUCKET=
S3_ENDPOINT_URL=
# Leave S3_ENDPOINT_URL blank for AWS S3; set for MinIO / on-prem S3
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=us-east-1
S3_ARTIFACTS_PREFIX=artifacts/


# ── Git PR Integration ───────────────────────────────────────────────────────
GIT_PROVIDER=github
GIT_BASE_URL=https://api.github.com
GIT_TOKEN=<GitHub personal access token>
GIT_OWNER=your-org
GIT_REPO=your-repo


# ── ELK / OpenSearch ─────────────────────────────────────────────────────────
ELK_HOST=https://your-elk-host:9200
ELK_USERNAME=elastic
ELK_PASSWORD=
# OR use API key instead of username/password:
ELK_API_KEY=
ELK_INDEX_PATTERN=logs-*
ELK_TIME_WINDOW_HOURS=24
ELK_MAX_HITS=50


# ── TestRail ─────────────────────────────────────────────────────────────────
TESTRAIL_BASE_URL=https://your-org.testrail.io
TESTRAIL_USERNAME=your-email@company.com
TESTRAIL_API_KEY=<TestRail → My Settings → API Keys>
TESTRAIL_SESSION_COOKIE=
TESTRAIL_PROJECT_ID=0
TESTRAIL_SUITE_ID=0


# ── Jenkins / Log Lookup ─────────────────────────────────────────────────────
JENKINS_BASE_URL=https://your-jenkins.company.com
JENKINS_USERNAME=your-jenkins-user
JENKINS_API_TOKEN=<Jenkins → Profile → Configure → API Token>
LOG_DIR=
LOG_TIME_WINDOW_HOURS=24


# ── Notifications ─────────────────────────────────────────────────────────────
# Teams incoming webhook — leave blank to disable
TEAMS_WEBHOOK_URL=

# Email / SMTP — leave SMTP_HOST blank to disable
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=
EMAIL_TO=qa-team@company.com,lead@company.com
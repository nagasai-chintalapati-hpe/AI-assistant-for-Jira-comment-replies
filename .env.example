# Jira Cloud 
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_USERNAME=your-email@company.com
JIRA_API_TOKEN=
JIRA_SEVERITY_FIELD_ID=customfield_12633

# Confluence
CONFLUENCE_BASE_URL=https://your-org.atlassian.net
CONFLUENCE_USERNAME=your-email@company.com
CONFLUENCE_API_TOKEN=
CONFLUENCE_SPACES=

# Copilot SDK
GITHUB_TOKEN=
COPILOT_API_KEY=
COPILOT_BASE_URL=https://models.inference.ai.azure.com
COPILOT_MODEL=gpt-4o
LLM_BACKEND=copilot

# RAG
CHROMA_PERSIST_DIR=.data/chroma
RAG_EMBEDDING_MODEL=all-MiniLM-L6-v2
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=50
RAG_TOP_K=5
PDF_UPLOAD_DIR=.data/pdfs

# Application
APP_HOST=0.0.0.0
APP_PORT=8000

LOG_LEVEL=INFO
MAX_COMMENTS=10
JIRA_WEBHOOK_SECRET=
VALIDATE_WEBHOOK_SIGNATURE=false
APP_BASE_URL=http://localhost:8000
ASSISTANT_DB_PATH=.data/assistant.db
ENV=development

# Git PR Integration 
GIT_PROVIDER=github
GIT_BASE_URL=https://api.github.com
GIT_TOKEN=
GIT_OWNER=your-org
GIT_REPO=your-repo

# ELK / OpenSearch 
ELK_HOST=http://localhost:9200
ELK_USERNAME=elastic
ELK_PASSWORD=
ELK_API_KEY=
ELK_INDEX_PATTERN=logs-*
ELK_TIME_WINDOW_HOURS=24
ELK_MAX_HITS=50

# TestRail
TESTRAIL_BASE_URL=https://your-org.testrail.io
TESTRAIL_USERNAME=your-email@company.com
TESTRAIL_API_KEY=
TESTRAIL_SESSION_COOKIE=
TESTRAIL_PROJECT_ID=0
TESTRAIL_SUITE_ID=0

# Notifications
TEAMS_WEBHOOK_URL=

# Email
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=
EMAIL_TO=

# Redis 
REDIS_ENABLED=true
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Dashboard Access
DASHBOARD_TOKEN=

# RabbitMQ 
QUEUE_ENABLED=false
RABBITMQ_URL=amqp://guest:guest@localhost/
QUEUE_NAME=jira_webhook_events
QUEUE_PREFETCH_COUNT=1

# S3
S3_BUCKET=jira-artifacts
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=us-east-1
S3_ARTIFACTS_PREFIX=artifacts/

# Jenkins
JENKINS_BASE_URL=https://jenkins.example.com
JENKINS_USERNAME=
JENKINS_API_TOKEN=

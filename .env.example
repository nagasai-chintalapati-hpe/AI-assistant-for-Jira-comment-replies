# Jira Cloud
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_USERNAME=your-email@company.com
JIRA_API_TOKEN=your-api-token

# Copilot SDK
COPILOT_API_KEY=
COPILOT_MODEL=claude-sonnet-4.5

# LLM provider (copilot|llama_cpp|local|openai_compat)
LLM_PROVIDER=copilot
LLM_BASE_URL=http://localhost:8080
LLM_API_KEY=

# Application
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
MAX_COMMENTS=10
WEBHOOK_SECRET=
APPROVAL_API_KEY=
ASSISTANT_DB_PATH=.data/assistant.db
ENV=development

# Notifications
TEAMS_WEBHOOK_URL=

# Email
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=
EMAIL_TO=

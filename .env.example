# ──────────────────────────────────────────────────────────────────
#  Jira Comment Assistant – Environment Variables (MVP v1)
#  Copy this file to `.env` and fill in your values.
# ──────────────────────────────────────────────────────────────────

# ── Jira Cloud ──────────────────────────────────────────────────
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_USERNAME=your-email@company.com
JIRA_API_TOKEN=your-api-token

# ── Copilot SDK (optional – leave blank for keyword-only mode) ──
COPILOT_API_KEY=
COPILOT_MODEL=claude-sonnet-4.5

# ── Application ─────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
MAX_COMMENTS=10
WEBHOOK_SECRET=
APPROVAL_API_KEY=
ASSISTANT_DB_PATH=.data/assistant.db
ENV=development

# ── Notifications (optional) ────────────────────────────────────
# Teams – incoming webhook URL for your channel
TEAMS_WEBHOOK_URL=

# Email – SMTP credentials (leave blank to disable)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=
EMAIL_TO=qa-team@company.com,lead@company.com
